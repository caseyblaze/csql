#!/usr/bin/env bash
set -euo pipefail

CONFIG_DIR="${HOME}/.config/cloud-sql-proxy"
STATE_DIR="${HOME}/.local/share/csql"

usage() {
  echo "Usage: csql <start|stop|status> [--env ENV]"
  echo ""
  echo "Commands:"
  echo "  start [--env ENV]   Start proxy instances (all envs or specific)"
  echo "  stop  [--env ENV]   Stop proxy instances (all envs or specific)"
  echo "  status              Show status of all proxy instances"
  echo "  completion zsh      Print zsh tab-completion script"
  echo ""
  echo "Examples:"
  echo "  csql start            # start all environments"
  echo "  csql start --env dev  # start only dev"
  echo "  csql stop --env prod  # stop only prod"
  echo "  csql status"
}

parse_env_flag() {
  local args=("$@")
  for i in "${!args[@]}"; do
    if [[ "${args[$i]}" == "--env" ]]; then
      echo "${args[$((i+1))]:-}"
      return
    fi
  done
  echo ""
}

no_configs_hint() {
  echo "No configs found in $CONFIG_DIR" >&2
  echo "" >&2
  echo "Create one to get started:" >&2
  echo "  \$EDITOR $CONFIG_DIR/dev.yaml" >&2
  echo "" >&2
  echo "Example config:" >&2
  echo "  instances:" >&2
  echo "    - name: project:region:instance" >&2
  echo "      port: 5432" >&2
}

get_config_files() {
  local env="$1"
  if [[ -n "$env" ]]; then
    local f="${CONFIG_DIR}/${env}.yaml"
    if [[ ! -f "$f" ]]; then
      echo "Error: config not found: $f" >&2
      exit 1
    fi
    echo "$f"
  else
    if [[ ! -d "$CONFIG_DIR" ]]; then
      no_configs_hint
      exit 1
    fi
    local files
    files=$(find "$CONFIG_DIR" -name "*.yaml" | sort)
    if [[ -z "$files" ]]; then
      no_configs_hint
      exit 1
    fi
    echo "$files"
  fi
}

env_from_file() {
  basename "$1" .yaml
}

# Generates a cloud-sql-proxy v2 TOML config from the user's YAML.
# Instances are expressed as indexed instance-connection-name-N keys with
# port and optional psc as query-string parameters per the cloud-sql-proxy spec.
generate_proxy_config() {
  local env_name="$1"
  local config_file="$2"
  local proxy_config="${STATE_DIR}/${env_name}-proxy.toml"
  local count i name port psc qs
  count=$(yq '.instances | length' "$config_file")
  {
    echo 'address = "127.0.0.1"'
    for i in $(seq 0 $((count - 1))); do
      name=$(yq -r ".instances[$i].name" "$config_file")
      port=$(yq -r ".instances[$i].port" "$config_file")
      qs="port=${port}"
      psc=$(yq -r ".instances[$i].psc // \"\"" "$config_file")
      if [[ "$psc" == "true" ]]; then
        qs="${qs}&psc=true"
      fi
      echo "instance-connection-name-${i} = \"${name}?${qs}\""
    done
  } > "$proxy_config"
  echo "$proxy_config"
}

# Kills and removes any per-instance PID files from the old architecture.
# Pattern {env}-[0-9]*.pid matches "dev-5432.pid" but not "dev.pid".
cleanup_legacy_pids() {
  local env_name="$1"
  local legacy_pid_file legacy_pid
  while IFS= read -r legacy_pid_file; do
    [[ -z "$legacy_pid_file" ]] && continue
    legacy_pid=$(cat "$legacy_pid_file" 2>/dev/null) || { rm -f "$legacy_pid_file"; continue; }
    if kill -0 "$legacy_pid" 2>/dev/null; then
      echo "  [migrate] ${env_name}: stopping legacy per-instance process (PID ${legacy_pid})" >&2
      kill "$legacy_pid" || true
      local waited=0
      while kill -0 "$legacy_pid" 2>/dev/null && [[ $waited -lt 5 ]]; do
        sleep 1
        ((waited++))
      done
    fi
    rm -f "$legacy_pid_file"
  done < <(find "${STATE_DIR}" -maxdepth 1 -name "${env_name}-[0-9]*.pid" 2>/dev/null)
}

cmd_start() {
  mkdir -p "$STATE_DIR"
  local env
  env=$(parse_env_flag "$@")
  local configs
  configs=$(get_config_files "$env")

  while IFS= read -r config_file; do
    local env_name count pid_file log_file proxy_config
    env_name=$(env_from_file "$config_file")
    pid_file="${STATE_DIR}/${env_name}.pid"
    log_file="${STATE_DIR}/${env_name}.log"

    cleanup_legacy_pids "$env_name"

    if [[ -f "$pid_file" ]]; then
      local existing_pid
      existing_pid=$(cat "$pid_file")
      if kill -0 "$existing_pid" 2>/dev/null; then
        count=$(yq '.instances | length' "$config_file")
        echo "  [skip] ${env_name}: already running (PID ${existing_pid}, ${count} instance(s))"
        continue
      fi
      rm -f "$pid_file"
    fi

    proxy_config=$(generate_proxy_config "$env_name" "$config_file")
    count=$(yq '.instances | length' "$config_file")

    cloud-sql-proxy --config-file "$proxy_config" >> "$log_file" 2>&1 &

    local pid=$!
    printf '%s\n' "$pid" > "$pid_file"
    echo "  [start] ${env_name}: ${count} instance(s) (PID ${pid})"
  done <<< "$configs"
}

cmd_stop() {
  mkdir -p "$STATE_DIR"
  local env
  env=$(parse_env_flag "$@")
  local configs
  configs=$(get_config_files "$env")

  while IFS= read -r config_file; do
    local env_name pid_file proxy_config
    env_name=$(env_from_file "$config_file")
    pid_file="${STATE_DIR}/${env_name}.pid"
    proxy_config="${STATE_DIR}/${env_name}-proxy.toml"

    cleanup_legacy_pids "$env_name"

    if [[ ! -f "$pid_file" ]]; then
      echo "  [skip] ${env_name}: not running"
      continue
    fi

    local pid
    pid=$(cat "$pid_file")

    if kill -0 "$pid" 2>/dev/null; then
      kill "$pid"
      local waited=0
      while kill -0 "$pid" 2>/dev/null && [[ $waited -lt 5 ]]; do
        sleep 1
        ((waited++))
      done
      echo "  [stop] ${env_name} (PID ${pid})"
    else
      echo "  [skip] ${env_name}: was not running (stale PID)"
    fi

    rm -f "$pid_file" "$proxy_config"
  done <<< "$configs"
}

cmd_status() {
  mkdir -p "$STATE_DIR"
  local configs
  configs=$(get_config_files "")

  printf "%-10s %-45s %-6s %-8s %s\n" "ENV" "INSTANCE" "PORT" "PID" "STATUS"
  printf "%-10s %-45s %-6s %-8s %s\n" "----------" "---------------------------------------------" "------" "--------" "-------"

  while IFS= read -r config_file; do
    local env_name pid_file env_pid status
    env_name=$(env_from_file "$config_file")
    pid_file="${STATE_DIR}/${env_name}.pid"
    env_pid="-"
    status="stopped"

    if [[ -f "$pid_file" ]]; then
      local raw_pid
      raw_pid=$(cat "$pid_file")
      if kill -0 "$raw_pid" 2>/dev/null; then
        env_pid="$raw_pid"
        status="running"
      else
        status="stopped (stale)"
      fi
    fi

    local count
    count=$(yq '.instances | length' "$config_file")
    for i in $(seq 0 $((count - 1))); do
      local name port
      name=$(yq -r ".instances[$i].name" "$config_file")
      port=$(yq -r ".instances[$i].port" "$config_file")
      printf "%-10s %-45s %-6s %-8s %s\n" "$env_name" "$name" "$port" "$env_pid" "$status"
    done
  done <<< "$configs"
}

cmd_completion() {
  local shell="${1:-}"
  case "$shell" in
    zsh)
      cat <<'EOF'
#compdef csql
_csql() {
  local config_dir="${HOME}/.config/cloud-sql-proxy"

  if (( CURRENT == 2 )); then
    local -a cmds
    cmds=(
      'start:Start proxy instances'
      'stop:Stop proxy instances'
      'status:Show status of all proxy instances'
      'help:Show usage'
    )
    _describe 'command' cmds
    return
  fi

  case ${words[2]} in
    start|stop)
      if [[ ${words[CURRENT-1]} == --env ]]; then
        local -a envs
        envs=(${config_dir}/*.yaml(N:t:r))
        _describe 'environment' envs
      else
        compadd -- --env
      fi
      ;;
  esac
}
compdef _csql csql
EOF
      ;;
    *)
      echo "Usage: csql completion zsh" >&2
      echo "Only zsh is supported." >&2
      exit 1
      ;;
  esac
}

SUBCOMMAND="${1:-}"
shift || true

case "$SUBCOMMAND" in
  start)      cmd_start "$@" ;;
  stop)       cmd_stop "$@" ;;
  status)     cmd_status "$@" ;;
  completion) cmd_completion "$@" ;;
  -h|--help|help|"") usage; exit 0 ;;
  *) echo "Unknown command: $SUBCOMMAND"; usage; exit 1 ;;
esac
